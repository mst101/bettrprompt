APP_NAME="BettrPrompt"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://app.localhost
LARAVEL_BASE_URL=https://app.localhost
APP_NAMESPACE=bp

APP_LOCALE=en-US
APP_FALLBACK_LOCALE=en-US
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

XDEBUG_MODE=off

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bettrprompt
DB_USERNAME=sail
DB_PASSWORD=password

POSTGRES_VERSION=17

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=bp:
HORIZON_PREFIX=bp:queue:

REDIS_CLIENT=phpredis
REDIS_PREFIX=
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

#MAIL_MAILER=log
MAIL_MAILER=smtp
MAIL_SCHEME=null
#MAIL_HOST=127.0.0.1
MAIL_HOST=smtp.eu.mailgun.org
#MAIL_PORT=2525
MAIL_PORT=587
MAIL_USERNAME=postmaster@mg.bettrprompt.ai
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@bettrprompt.ai"
MAIL_FROM_NAME="${APP_NAME}"

# --- Mailgun ---
# For local development, use MAIL_MAILER=log
# E2E tests use MAIL_MAILER=array to capture emails without sending
# For production, use MAIL_MAILER=smtp with settings below
MAILGUN_DOMAIN=mg.bettrprompt.ai
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.eu.mailgun.net
MAILGUN_WEBHOOK_SIGNING_KEY=

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- n8n Configuration ---

# Container & Access URLs
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST=n8n.localhost
N8N_BASE_URL=https://n8n.localhost
N8N_PUBLIC_URL=https://n8n.localhost/
N8N_WEBHOOK_URL=http://localhost:5678/

# Internal Laravel communication (use http://n8n:5678 for Docker, http://localhost:5678 for native)
N8N_INTERNAL_URL=http://n8n:5678
LARAVEL_BASE_URL_INTERNAL=http://laravel.test

# Authentication (API key preferred over basic auth in production)
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJmNGFkZmRmMy01Y2IzLTRhZTctOTQ3MC03MDhhNWQzMjBiZTIiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwiaWF0IjoxNzY3MDg5NzMwfQ.UNuZ5rU5VsSwadF22Z9khmeIP3A9QhuolBcYa3Tn78s
N8N_API_KEY_LIVE=
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=info@hiddengambia.com
N8N_BASIC_AUTH_PASSWORD=

# Encryption & Security
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=

# Workflows
N8N_WORKFLOW_0_ID=6emXrUvGWYZFohin
N8N_WORKFLOW_1_ID=ygzY2ffYVmvnC005
N8N_WORKFLOW_2_ID=07heW8sgKaJqsfaa
N8N_WORKFLOW_0_ID_LIVE=
N8N_WORKFLOW_1_ID_LIVE=
N8N_WORKFLOW_2_ID_LIVE=

# Database (n8n stores its data in PostgreSQL)
N8N_DB_TYPE=postgresdb
N8N_DB_HOST=pgsql
N8N_DB_PORT=5432
N8N_DB_DATABASE=bettrprompt_n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=

# Optional Configuration
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
GENERIC_TIMEZONE=Europe/London

# --- Laravel Reverb (WebSockets) ---
# REVERB_PORT is 8080 for local and 443 for production
# REVERB_SCHEME is http for local and https for production
REVERB_APP_ID=1
REVERB_APP_KEY=base64:YOUR_REVERB_APP_KEY_HERE=
REVERB_APP_SECRET=your_reverb_app_secret_here
REVERB_HOST="reverb"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_VERIFY_BROADCASTER_TOKEN=false

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="app.localhost"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- OpenAI ---
OPENAI_API_KEY=

# --- MaxMind GeoIP ---
# Sign up for free at: https://www.maxmind.com/en/geolite2/signup
# Get Account ID and License Key from MaxMind account
GEOIP_ENABLED=true
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
