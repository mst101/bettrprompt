APP_NAME="AI Buddy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://app.localhost
LARAVEL_BASE_URL=https://app.localhost
APP_NAMESPACE=aib

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=personality
DB_USERNAME=root
DB_PASSWORD=

# For E2E tests, create a .env.e2e file and use:
# DB_DATABASE=personality_e2e
# APP_ENV=e2e

POSTGRES_VERSION=17

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- n8n ---
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST=n8n.localhost
# Public URL used in webhook payloads and OAuth redirects (adjust if using a domain)
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASE_URL=https://n8n.localhost

# Basic auth (recommended for local; in prod, use SSO/proxy hardening)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Internal URL (for Laravel to call n8n)
# Use http://n8n:5678 for Docker/Sail, or http://localhost:5678 for native installation
N8N_INTERNAL_URL=http://n8n:5678

# External URL (public - used for OAuth callbacks)
N8N_PUBLIC_URL=https://n8n.localhost/

# Encrypt credentials in n8n
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=

# Timezone
GENERIC_TIMEZONE=Europe/London

# Use Sail's Postgres
N8N_DB_TYPE=postgresdb
N8N_DB_HOST=pgsql
N8N_DB_PORT=5432
N8N_DB_DATABASE=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=n8n-db-password

# Optional hardening (you can flip these later)
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# Internal Laravel base URL for n8n HTTP nodes (use the caddy service inside Sail)
LARAVEL_BASE_URL_INTERNAL=http://laravel.test

# --- Laravel Reverb (WebSockets) ---
# REVERB_PORT is 8080 for local and 443 for production
# REVERB_SCHEME is http for local and https for production
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="reverb"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="app.localhost"
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- OpenAI ---
OPENAI_API_KEY=

# --- MaxMind GeoIP ---
# Sign up for free at: https://www.maxmind.com/en/geolite2/signup
# Get Account ID and License Key from MaxMind account
GEOIP_ENABLED=true
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
