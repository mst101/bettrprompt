# Global options - no automatic HTTPS generation
# Certificates are provided by mkcert

(app_common) {
    encode gzip
    log {
        output stdout
    }
}

# Laravel application
# Handles both HTTP and HTTPS, automatically redirects HTTP → HTTPS
app.localhost {
    # Encode gzip for non-WebSocket traffic only
    @not_websockets {
        not header Connection *Upgrade*
    }
    encode @not_websockets gzip

    log {
        output stdout
    }

    # WebSocket support for Laravel Reverb
    # Match requests to /app/* which is the Reverb WebSocket endpoint
    @websockets {
        path /app/*
    }
    reverse_proxy @websockets reverb:8080

    # Regular HTTP traffic to Laravel
    reverse_proxy laravel.test:80

    # Use mkcert certificates (valid until 31 March 2028)
    tls /app/certs/app.localhost.pem /app/certs/app.localhost.key
}

# n8n workflow automation
# Handles both HTTP and HTTPS, automatically redirects HTTP → HTTPS
n8n.localhost {
    import app_common
    reverse_proxy n8n:5678

    # Use mkcert certificates (valid until 31 March 2028)
    tls /app/certs/n8n.localhost.pem /app/certs/n8n.localhost.key
}
