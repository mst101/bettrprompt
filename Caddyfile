# Global options for local development
{
    # Enable automatic HTTPS with self-signed certificates for .localhost domains
    # Caddy will automatically redirect HTTP → HTTPS
    local_certs
}

(app_common) {
    encode gzip
    log {
        output stdout
    }
}

# Laravel application
# Handles both HTTP and HTTPS, automatically redirects HTTP → HTTPS
app.localhost {
    # Encode gzip for non-WebSocket traffic only
    @not_websockets {
        not header Connection *Upgrade*
    }
    encode @not_websockets gzip

    log {
        output stdout
    }

    # WebSocket support for Laravel Reverb
    # Match requests to /app/* which is the Reverb WebSocket endpoint
    @websockets {
        path /app/*
    }
    reverse_proxy @websockets reverb:8080

    # Regular HTTP traffic to Laravel
    reverse_proxy laravel.test:80
}

# n8n workflow automation
# Handles both HTTP and HTTPS, automatically redirects HTTP → HTTPS
n8n.localhost {
    import app_common
    reverse_proxy n8n:5678
}
