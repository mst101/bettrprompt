{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vue-tsc && vite build && vite build --ssr",
        "dev": "vite",
        "lint": "eslint resources/js tests-frontend --fix",
        "format": "prettier --write resources/ tests-frontend",
        "test": "vitest",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:watch": "vitest watch",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:data-collection": "playwright test --config=playwright-data-collection.config.ts",
        "test:data-collection:headed": "playwright test --config=playwright-data-collection.config.ts --headed",
        "test:data-collection:debug": "playwright test --config=playwright-data-collection.config.ts --debug",
        "data-collection:clear": "bash scripts/clear-data-collection.sh",
        "prepare": "husky"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.3.11",
        "@playwright/test": "^1.58.0",
        "@rushstack/eslint-patch": "^1.15.0",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.1.18",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^25.0.10",
        "@vitejs/plugin-basic-ssl": "^2.1.4",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/server-renderer": "^3.5.27",
        "@vue/test-utils": "^2.4.6",
        "axios": "^1.13.2",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.2",
        "eslint-plugin-vue": "^10.7.0",
        "happy-dom": "^20.3.7",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^2.1.0",
        "lint-staged": "^16.2.7",
        "postcss": "^8.5.6",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vue": "^3.5.27",
        "vue-tsc": "^3.2.3"
    },
    "dependencies": {
        "@fullstory/browser": "^2.0.6",
        "@heroicons/vue": "^2.2.0",
        "@intlify/unplugin-vue-i18n": "^11.0.3",
        "@vueuse/core": "^14.1.0",
        "dompurify": "^3.3.1",
        "flag-icons": "^7.5.0",
        "laravel-echo": "^2.3.0",
        "lucide-vue-next": "^0.562.0",
        "marked": "^17.0.1",
        "pinia": "^3.0.4",
        "pusher-js": "^8.4.0",
        "tailwindcss-rtl": "^0.9.0",
        "vue-i18n": "^11.2.8"
    },
    "lint-staged": {
        "resources/**/*.{js,ts,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "tests-frontend/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "app/**/*.php": [
            "./vendor/bin/pint"
        ],
        "config/**/*.php": [
            "./vendor/bin/pint"
        ],
        "database/**/*.php": [
            "./vendor/bin/pint"
        ],
        "routes/**/*.php": [
            "./vendor/bin/pint"
        ],
        "tests/**/*.php": [
            "./vendor/bin/pint"
        ]
    }
}
