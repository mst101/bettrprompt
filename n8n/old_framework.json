// Build the system prompt for framework selection\nconst systemPrompt = `You are an expert in prompt engineering frameworks and personality-based communication.\n\nYour task is to:\n1. Analyse the user's task description and personality type\n2. Select the SINGLE most appropriate prompt framework from the provided matrix\n3. Explain WHY this framework is optimal (2-3 sentences)\n4. Generate 3-5 clarifying questions that will help create the best possible prompt\n\nThe questions should:\n- Be specific to the chosen framework's requirements\n- Help gather missing context or details\n- Be tailored to the user's personality type\n- Build upon each other logically\n- Be answerable in 1-3 sentences each\n\nYou MUST respond ONLY with valid JSON in this exact format:\n{\n  \"selected_framework\": \"Framework Name\",\n  \"reasoning\": \"2-3 sentence explanation of why this framework is optimal\",\n  \"questions\": [\n    \"Question 1 text?\",\n    \"Question 2 text?\",\n    \"Question 3 text?\"\n  ]\n}\n\nDo not include any text outside the JSON object. The questions array must contain 3-5 questions.`;\n\n// Build the user message\nconst inputData = $input.first().json;\n\nconst userMessage = `Framework Selection Matrix:\n\n${inputData.framework_matrix}\n\n---\n\nPersonality Type: ${inputData.personality_type}${inputData.trait_info}\n\nTask Description:\n${inputData.task_description}\n\n---\n\nBased on the above information, select the optimal framework and generate clarifying questions.`;\n\nreturn {\n  prompt_run_id: inputData.prompt_run_id,\n  personality_type: inputData.personality_type,\n  task_description: inputData.task_description,\n  system_prompt: systemPrompt,\n  user_message: userMessage\n};
